# =============================================================
# Sciqus Assessment — .gitignore
# =============================================================

# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/

# -----------------------------------------------
# Virtual Environment
# -----------------------------------------------
venv/
.venv/
env/
.env_folder/

# -----------------------------------------------
# Environment Variables (NEVER commit secrets!)
# -----------------------------------------------
.env

# -----------------------------------------------
# Flask / Runtime
# -----------------------------------------------
instance/
.flask_session/

# -----------------------------------------------
# OS Files
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------
# IDE / Editor
# -----------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/

# -----------------------------------------------
# Misc
# -----------------------------------------------
*.bak
*.swp
*.tmp
